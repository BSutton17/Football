# Client environment variables (Vite). Copy to `.env` for local overrides; set in the host's build
# settings (e.g. Netlify) for production.

# The game server the client connects to.
#   • Leave UNSET for local development — defaults to http://localhost:3001 (run the local server).
#   • Set to the deployed server to use it (works from localhost or the deployed client). On Netlify
#     this points the live site at the Heroku server:
# VITE_SERVER_URL=https://football-server-3a8e8a32d792.herokuapp.com
